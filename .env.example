# Vercel KV credentials (auto-provided by Vercel when KV is linked to your project)
# For local development: run `vercel env pull .env.local` after linking your project
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# Password to protect the dashboard (set this in Vercel project settings → Environment Variables)
APP_PASSWORD=your_password_here
